# PostgreSQL (used by both the app and the postgres container)
POSTGRES_USER=lex
POSTGRES_PASSWORD=lex
POSTGRES_DB=lextranslate
DATABASE_URL=postgresql+asyncpg://lex:lex@postgres:5432/lextranslate

# Redis
REDIS_URL=redis://redis:6379

# Auth — generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_OUTPUT_OF__openssl_rand_hex_32

# LLM provider: anthropic | openai | groq
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# OCR
OCR_PADDLE_LANG=pt
ENABLE_PADDLE_OCR=0

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=lex-translate
